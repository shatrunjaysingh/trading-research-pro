# ─────────────────────────────────────────────────────────────────────────────
# Trading Research — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full connection URL (used by app). Overrides individual DB_* vars.
DATABASE_URL=postgresql://trading_user:trading_pass@localhost:5433/trading_research

# Individual components — used by docker-compose and AWS RDS configuration.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=trading_research
DB_USER=trading_user
DB_PASSWORD=trading_pass

# AWS RDS example (swap DATABASE_URL above when deploying):
# DATABASE_URL=postgresql://trading_user:StrongPass123@mydb.xxxx.us-east-1.rds.amazonaws.com:5432/trading_research?sslmode=require

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Reddit API (optional — enables Reddit social sentiment) ───────────────────
# Register a free "script" app at https://www.reddit.com/prefs/apps
# Use http://localhost:8080 as the redirect URI.
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Generate App Password at: myaccount.google.com → Security → App passwords
EMAIL_SENDER=you@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8501

# ── pgAdmin (optional, --profile tools) ──────────────────────────────────────
PGADMIN_EMAIL=admin@tradingresearch.com
PGADMIN_PASSWORD=Admin123!
PGADMIN_PORT=5050

# ── Polygon.io ────────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty for local dev (defaults to localhost).
# Set to your Vercel URL when deploying: https://yourapp.vercel.app
CORS_ORIGINS_RAW=

# ── Secret key (production) ───────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
