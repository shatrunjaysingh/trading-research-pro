# Frontend environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Dev:    Leave VITE_API_URL unset — Vite proxy forwards /api/* to localhost:8000
# Prod:   Set VITE_API_URL in Vercel dashboard (Project → Settings → Env Vars)
#         or in .env.local for native (Capacitor) builds

# URL of your deployed backend (no trailing slash)
VITE_API_URL=https://trading-research-pro-api.onrender.com

# Examples:
# VITE_API_URL=http://192.168.1.42:8000          ← LAN / mobile testing
# VITE_API_URL=https://trading-research-pro-api.onrender.com  ← Render free tier
