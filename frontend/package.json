{
  "name": "trading-research-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":              "vite",
    "build":            "tsc && vite build",
    "preview":          "vite preview",
    "gen:assets":       "node scripts/generate-assets.mjs",
    "gen:icons":        "npx capacitor-assets generate",
    "cap:init":         "npx cap init 'TradingResearch Pro' com.tradingresearch.pro --web-dir dist",
    "cap:sync":         "npm run build && npx cap sync",
    "cap:ios":          "npm run cap:sync && npx cap open ios",
    "cap:android":      "npm run cap:sync && npx cap open android",
    "cap:run:ios":      "npm run cap:sync && npx cap run ios",
    "cap:run:android":  "npm run cap:sync && npx cap run android",
    "setup:mobile":     "npm run gen:assets && npm run gen:icons && npx cap add ios && npx cap add android && npm run cap:sync"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@tanstack/react-query": "^5.45.1",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^3.8.1",
    "vite-plugin-pwa": "^1.3.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
